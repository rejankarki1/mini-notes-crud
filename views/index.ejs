<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/style.css">

    <title>Mini Notes</title>
</head>

<body>

    <header class="header-title">

        <h1>✍️ Mini Notes</h1>

        <a href="/notes/new">
            <button class="create-main-btn">
                Create Note
            </button>
        </a>

    </header>

    <div class="container">

        <h2 class="section-title">All Notes</h2>

        <div class="notes-container">

            <% notes.forEach((note) => { %>

                <div class="note-card">

                    <h3>
                        <%= note.title %>
                    </h3>

                    <p>
                        <%= note.description %>
                    </p>

                    <div class="btns">

                        <a href="/notes/<%= note.id %>/edit">

                            <button class="edit-btn">
                                Edit
                            </button>

                        </a>

                        <form action="/notes/<%= note.id %>?_method=DELETE" method="POST">

                            <button class="delete-btn">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>

            <% }) %>

        </div>

    </div>

    <script src="/app.js"></script>

</body>
</html>